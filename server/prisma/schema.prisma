// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    // 'customer' or 'provider'
  displayName  String    @map("display_name")
  phone        String?
  location     String?
  bio          String?
  profileImage String?   @map("profile_image")
  profession   String?
  createdAt    DateTime  @default(now()) @map("created_at")
  
  listings     Listing[]
  bookingsAsCustomer Booking[] @relation("CustomerBookings")
  bookingsAsProvider Booking[] @relation("ProviderBookings")
  reviewsAsCustomer Review[] @relation("CustomerReviews")
  reviewsAsProvider Review[] @relation("ProviderReviews")

  @@map("users")
}

model Listing {
  id          String    @id @default(uuid())
  providerId  String    @map("provider_id")
  provider    User      @relation(fields: [providerId], references: [id])
  title       String
  description String?
  category    String
  priceEtb    Float     @default(0) @map("price_etb")
  location    String?
  phone       String?
  ratingAvg   Float     @default(0) @map("rating_avg")
  reviewCount Int       @default(0) @map("review_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  bookings    Booking[]
  reviews     Review[]

  @@map("listings")
}

model Booking {
  id            String   @id @default(uuid())
  listingId     String   @map("listing_id")
  listing       Listing  @relation(fields: [listingId], references: [id])
  customerId    String   @map("customer_id")
  customer      User     @relation("CustomerBookings", fields: [customerId], references: [id])
  providerId    String   @map("provider_id")
  provider      User     @relation("ProviderBookings", fields: [providerId], references: [id])
  status        String   @default("pending")
  scheduledDate String?  @map("scheduled_date")
  notes         String?
  amountEtb     Float    @default(0) @map("amount_etb")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  review        Review?

  @@map("bookings")
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique @map("booking_id")
  booking    Booking  @relation(fields: [bookingId], references: [id])
  listingId  String   @map("listing_id")
  listing    Listing  @relation(fields: [listingId], references: [id])
  customerId String   @map("customer_id")
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  providerId String   @map("provider_id")
  provider   User     @relation("ProviderReviews", fields: [providerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reviews")
}
